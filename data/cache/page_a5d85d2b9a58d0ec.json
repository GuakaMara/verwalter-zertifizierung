  "html": "<!DOCTYPE html>\n<html class=\"pl\" lang=\"de\">\n<head>\n<title>\nPrüfung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz\n- IHK Hanau-Gelnhausen-Schlüchtern\n</title>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/>\n<link rel=\"shortcut icon\" type=\"image/x-icon\" href=\"/blueprint/servlet/resource/blob/424306/adaeba3a85f5f971aa16e35dbb62afdb/huihk24-channel-favicon.ico\"/>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/>\n<meta name=\"cms-version\" content=\"1-SNAPSHOT-2026-02-18T23:01:56Z-cae-live-blue-3-56cb65f9c6-mq4cb \"/>\n<meta name=\"description\" content=\"Alle Informationen zur Pr&amp;uuml;fung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz.\n\"/>\n<meta name=\"robots\" content=\"index,follow\"/>\n<meta name=\"keywords\" content=\"\"/>\n<meta property=\"og:title\" content=\"Pr&uuml;fung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz\" />\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:url\" content=\"https://www.ihk.de/hanau/standort/immobilien/pruefung-zum-zertifizierter-weg-verwalter-5716906\" />\n<meta property=\"og:image\" content=\"https://www.ihk.de/blueprint/servlet/resource/blob/4033190/58dc25b523b289c314f8842eaa8157c4/facebook-twitter-share-logo-data.jpg\" />\n<meta property=\"og:description\" content=\"Alle Informationen zur Pr&uuml;fung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz.\n\" />\n<meta property=\"og:site_name\" content=\"IHK Hanau-Gelnhausen-Schlüchtern\" />\n<meta name=\"twitter:card\" content=\"summary\" />\n<meta name=\"twitter:site\" content=\"com.coremedia.blueprint.cae.contentbeans.CMPictureImpl$$[id=4033190]\" />\n<meta name=\"twitter:title\" content=\"Pr&uuml;fung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz\" />\n<meta name=\"twitter:description\" content=\"Alle Informationen zur Pr&uuml;fung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz.\n\" />\n<meta name=\"twitter:image\" content=\"https://www.ihk.de/blueprint/servlet/resource/blob/4033190/58dc25b523b289c314f8842eaa8157c4/facebook-twitter-share-logo-data.jpg\" />\n<meta name=\"csrf-token\" content=\"wJjRR6GdW0HhMS7uVXP5u0cVZSZplzGTey98XFztjeG8zwbMpPq3Icf4ayPMVEzdM17NjHYgSB9foQi-TU1NbmSPtNOLqjT9\"/>\n<script id=\"ccm19\" src=\"https://ihk24.epccm19.com/app.js?apiKey=1ea1dd88e74e9deb745262fb3105eb9babfd935ba151be83&amp;domain=23b9a56\" referrerpolicy=\"origin\"></script>\" referrerpolicy=\"origin\"></script>\n<meta name=\"google-site-verification\" content=\"MXZf7bi1u8NUI94rp0bNsvorcksV1RFEYlQ1iyjA_CE\" />\n<meta name=\"google-site-verification\" content=\"qo23niRFGiBOgfxEi9qKWO25B6mW9miOb1fTwOo50oc\" />\n<link href=\"/blueprint/servlet/feed/426308\" rel=\"alternate\" type=\"application/rss+xml\"\ntitle=\"\"/>\n<script type=\"application/ld+json\">{\n\"@context\" : \"https://schema.org\",\n\"@type\" : \"Person\",\n\"email\" : \"K.Schmidt@hanau.ihk.de\",\n\"familyName\" : \"Schmidt (Syndikusrechtsanwältin)\",\n\"givenName\" : \"Kathrin\",\n\"honorificSuffix\" : \"RA\",\n\"telephone\" : \"06181 92 90-84 10\"\n}</script><script type=\"application/ld+json\">{\n\"@context\" : \"https://schema.org\",\n\"@type\" : \"Person\",\n\"email\" : \"e.mujadzic@hanau.ihk.de\",\n\"familyName\" : \"Mujadzic\",\n\"givenName\" : \"Ezgi\",\n\"telephone\" : \"06181 9290 8412\"\n}</script>\n<link rel=\"preconnect\" href=\"https://code.etracker.com\"/>\n<link rel=\"preload\" href=\"/blueprint/servlet/resource/crblob/5579336/ad109ffb72027621ba35ce7c1015e1a8/icons-woff2-data.woff2\" as=\"font\" crossorigin=\"anonymous\"/>\n<link rel=\"preload\" href=\"/blueprint/servlet/resource/crblob/5579344/c9d20f25374ac3bddb796544e0aafba5/ihk24-fontawesome-woff2-data.woff2\" as=\"font\"\ncrossorigin=\"anonymous\"/>\n<link rel=\"preload\" href=\"/blueprint/servlet/resource/crblob/5579352/23aeda9396f2298ffa334c5daeca1e48/korb-webfont-woff2-data.woff2\" as=\"font\"\ncrossorigin=\"anonym