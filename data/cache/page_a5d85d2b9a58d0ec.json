s/ihk24-2022/js/eventteaserlargeslider-6216484-8.js',\ngfiEventoverviewJSLink : '/blueprint/servlet/resource/themes/ihk24-2022/js/eventoverview-6216482-8.js',\ngfiCommonContentJSLink : '/blueprint/servlet/resource/themes/ihk24-2022/js/common-content-6126968-7.js',\ngfiCardSliderJSLink : '/blueprint/servlet/resource/themes/ihk24-2022/js/cardslider-6620868-3.js',\n};\nihk.settings = {\netrackerCookieless : true,\nuserlikeWidgetKey: '',\nuseOriginalChattoolButton: false,\nnavigationItemsUrl: '',\nlandingPageUrl:\"\",\ndoIhkTestUrl:\"\",\nbIhkTestUrl:\"\"\n};\n</script>\n<header class=\"page-header\">\n<a href=\"/hanau/\" class=\"logo\" tabindex=\"0\" title=\"IHK Hanau-Gelnhausen-Schlüchtern\"><img id=\"logo-infobar\" src=\"/blueprint/servlet/resource/blob/426232/9d30ac4d4efd0f24ac65538fba5325cf/logo-ihk-data.png\" alt=\"Logo\"/></a>\n<ul class=\"contact-nav\">\n<li>\n<a href=\"tel:061819290-0\" class=\"phone\" title=\"06181 9290-0\" data-analytics-action=\"Click\" data-analytics-category=\"Kontakt\" data-analytics-object=\"Kontakt\"\nonmousedown=\"if (typeof (ET_Event) !== 'undefined') {_etracker.sendEvent(new et_ClickEvent('Kontakt', 'Kontakt'))}\" target=\"_blank\" rel=\"noopener\" >06181 9290-0</a>\n</li>\n</ul>\n<div class=\"search\" data-id=\"header-search-wrapper\">\n<button class=\"open-search\">Suche</button>\n<button class=\"close-search\">Suche verlassen</button>\n<form action=\"/hanau/goto/424312\" method=\"post\"\ndata-search-actionid=\"424312\">\n<div class=\"container small\">\n<div class=\"outer\">\n<label for=\"search-field-header\" class=\"visually-hidden\">Suchbegriff</label>\n<input type=\"text\" id=\"search-field-header\" name=\"query\" class=\"search-field\"\nplaceholder=\"Suchbegriff oder Nr.\">\n<button type=\"submit\" title=\"Suche\" id=\"search-submit-header\"\nclass=\"search-submit\" aria-label=\"Suche starten\"></button>\n</div>\n</div>\n<input type=\"hidden\" name=\"_CSRFToken\" value=\"wJjRR6GdW0HhMS7uVXP5u0cVZSZplzGTey98XFztjeG8zwbMpPq3Icf4ayPMVEzdM17NjHYgSB9foQi-TU1NbmSPtNOLqjT9\"/>\n</form>\n</div>\n<button class=\"toggle-nav\" data-id=\"main-navigation-toggle-button\">\n<span> Menü</span>\n</button>\n<nav data-id=\"main-navigation-wrapper\">\n<div class=\"overlay-holder\"></div>\n<div class=\"primary\" data-root-url=\"5716906\"\ndata-base-url=\"/blueprint/servlet/serviceport/layernavigation/v2/\"\ndata-page-content-id=\"5716906\"\ndata-show-opened-menu=\"false\"\n></div>\n<div class=\"secondary\">\n<ul>\n<li class=\"secondary-nav-item\" data-is-channel=\"false\"\ndata-root-url=\"3283656\" >\n<a href=\"https://news.hanau.ihk.de/anmeldung.jsp\" class=\"extern\" title=\"externer Link\" data-analytics-action=\"Link\" data-analytics-category=\"External\" data-analytics-object=\"https://news.hanau.ihk.de/anmeldung.jsp\"\nonmousedown=\"if (typeof (ET_Event) !== 'undefined') {_etracker.sendEvent(new et_LinkEvent('https://news.hanau.ihk.de/anmeldung.jsp', 'External'))}\" >Newsletter</a>\n</li>\n<li class=\"secondary-nav-item\" data-is-channel=\"true\"\ndata-root-url=\"425124\" >\n<a href=\"/hanau/servicemarken/ueber-uns\">Über uns</a>\n</li>\n<li class=\"secondary-nav-item\" data-is-channel=\"true\"\ndata-root-url=\"425144\" >\n<a href=\"/hanau/servicemarken/service\">Service</a>\n</li>\n<li class=\"secondary-nav-item\" data-is-channel=\"false\"\ndata-root-url=\"5760104\" >\n<a href=\"/hanau/system/veranstaltungssuche/vstsuche-antrago/5760104\">Veranstaltungen</a>\n</li>\n</ul>\n</div>\n<div class=\"meta\">\n<ul>\n<li class=\"contact\">\n<a href=\"mailto:info@hanau.ihk.de\" class=\"email\" title=\"Kontakt\" data-analytics-action=\"Click\" data-analytics-category=\"Kontakt\" data-analytics-object=\"Kontakt\"\nonmousedown=\"if (typeof (ET_Event) !== 'undefined') {_etracker.sendEvent(new et_ClickEvent('Kontakt', 'Kontakt'))}\" target=\"_blank\" rel=\"noopener\" >Kontakt</a>\n</li>\n<li class=\"icons\">\n<ul>\n<li class=\"sign-language\">\n<a href=\"/hanau/gebaerdensprache-4978408\" tabindex=\"0\" title=\"Gebärdensprache\">Gebärdensprache</a>\n</li>\n<li class=\"simple-language\">\n<a href=\"/hanau/leichte-sprache-4950808\" tabindex=\"0\" title=\"Leichte Sprache\">Leichte Sprache</a>\n</li>\n<li class=\"login\">\n<a href=\"/hanau/loginseite-424354?view=\" title=\"Login\"\nonmousedown=\"\" >Login</a>\n</li>\n</ul>\n</li>\n</ul>\n</div>\n</nav>\n</header> <div class=\"page-wrapper\">\n<div class=\"page-details \">\n<nav class=\"breadcrumb-list-wrapper\" aria-label=\"Seitenpfad\">\n<p id=\"breadcrumb-info\" class=\"visually-hidden\">Sie befinden sich hier</p>\n<ol class=\"breadcrumb\" aria-describedby=\"breadcrumb-info\">\n<li class=\"breadcrumb-item\" >\n<a id='breadcrumb-item0' href=\"/hanau/\">Home</a>\n</li>\n<li class=\"breadcrumb-item\" >\n<a id='breadcrumb-item1' href=\"/hanau/standort\">Handel, Standort und Verkehr</a>\n</li>\n<li class=\"breadcrumb-item noClick\" data-item-id=\"4003226\" ><a\nhref=\"/hanau/standort?param=immobilien\" id=\"breadcrumb-item2\">Immobilien</a>\n</li>\n<li aria-current=\"page\"> Prüfung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz</li>\n</ol>\n</nav>\n<section aria-label=\"Dokumentennummer\" class=\"document-number desktopOnly\"\nid=\"gfi-document-id\">Nr. 5716906</section>\n</div>\n<div class=\"page-content has-sidebar\">\n<div class=\"container large\" >\n<div class=\"row\">\n<main id=\"main\" role=\"main\" class=\"main-col \">\n<div class=\"richtext\">\n<span class=\"kicker\" >Standortpolitik</span>\n<h1 class=\"h1\" >Prüfung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz</h1>\n<div class=\"text initial\">\nAb Dezember 2023 haben Wohnungseigentümer als Bestandteil der ordnungsgemäßen Verwaltung des Eigentums einen Anspruch auf einen zertifizierten WEG-Verwalter. Die Bestellung eines zertifizierten Verwalters steht dabei im Ermessen der Eigentümergemeinschaft. Die Zertifizierung ist daher ein Kann und kein Muss. Die Vollversammlung der Industrie- und Handelskammer Hanau-Gelnhausen-Schlüchtern hat am 8. Dezember 2022 die Prüfungsordnung für die Prüfung zum Zertifizierten Verwalter nach § 26a des Wohnungseigentumsgesetzes beschlossen. Diese Prüfungsordnung ist mit der Veröffentlichung im Mitteilungsblatt „Wirtschaftsraum Hanau-Kinzigtal“ Ausgabe April in Kraft getreten.\n</div>\n<div class=\"anchorlinks\">\n<ul class=\"anchors\">\n<li><a href=\"#titleInText0\" data-index=\"0\">Prüfungsaufbau</a></li>\n<li><a href=\"#titleInText1\" data-index=\"1\">Prüfungsvorbereitung</a></li>\n<li><a href=\"#titleInText2\" data-index=\"2\">Prüfungsgebühr</a></li>\n<li><a href=\"#titleInText3\" data-index=\"3\">Prüfungstermine und Anmeldung</a></li>\n</ul>\n</div>\n<div class=\"detail-text\">\n<h2>Prüfungsaufbau</h2>\n<div class=\"text\">\nDie Prüfung besteht aus einem schriftlichen und einem mündlichen Teil. Die schriftliche Prüfung dauert 90 Minuten. Sie umfasst rechtliche, kaufmännische und technische Themenbereiche sowie sowie Grundlagen der Immobilienwirtschaft.\n</div>\n<div class=\"text\">\nWenn die schriftliche Prüfung in allen Themenbereichen bestanden ist, wird die mündliche Prüfung durchgeführt. Die mündlichen Prüfungen finden i.d.R. ein bis zwei Wochen nach dem schriftlichen Prüfungstermin statt. Die Prüfung wird von drei sachkundigen Prüfern abgenommen und dauert 15 Minuten.\n</div>\n<div class=\"text\">\nWeitere Details der Prüfung sind in der Verordnung über die Prüfung zum zertifizierten Verwalter nach dem Wohnungseigentumsgesetz (<a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"https://www.gesetze-im-internet.de/zertverwv/\" target=\"_blank\" rel=\"noopener\">ZertVerwV</a>) und in der Prüfungssatzung der IHK geregelt. Der <a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"https://www.dihk.de/resource/blob/67830/a1ba350fb8401daad4f1671ebe8676b8/dihk-rahmenplan-weg-verwalter-data.pdf\" target=\"_blank\" rel=\"noopener\">Rahmenplan</a> der Prüfungsinhalte gibt Aufschluss über die konkreten Lerninhalte und -ziele der Prüfung.\n</div>\n<h2>Prüfungsvorbereitung</h2>\n<div class=\"text\">\nEine Vorbereitung auf die Prüfung zum zertifizierten WEG-Verwalter sieht die Verordnung nicht vor. Um die notwendigen Kenntnisse für die Prüfung zu erwerben, gibt es entsprechende Fachliteratur sowie Vorbereitungsseminare von diversen Veranstaltern. Das <a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"http://www.wis.ihk.de/\" target=\"_blank\" rel=\"noopener\">Weiterbildungs-Informations-System WIS</a> bieten einen Überblick über die verschiedenen Angebote unter dem Stichwort „Zertifizierter Verwalter“.\n</div>\n<h2>Prüfungsgebühr</h2>\n<table>\n<tbody>\n<tr>\n<td>Vollständige Prüfung schriftlich und mündlich</td>\n<td>235 €</td>\n</tr>\n<tr>\n<td>Wiederholung der mündlichen Prüfung</td>\n<td>185 €</td>\n</tr>\n<tr>\n<td colspan=\"2\"><strong>Bearbeitungsgebühr bei Rücktritt von einer Prüfung nach erfolgter Anmeldung</strong></td>\n</tr>\n<tr>\n<td>bis 6 Wochen vor der Prüfung</td>\n<td>30% der Prüfungsgebühr</td>\n</tr>\n<tr>\n<td>später als 6 Wochen vor der Prüfung</td>\n<td>50% der Prüfungsgebühr</td>\n</tr>\n<tr>\n<td>später als 7 Tage vor der Prüfung</td>\n<td>85% der Prüfungsgebühr</td>\n</tr>\n</tbody>\n</table>\n<div class=\"text\">\nDer Preis gilt pro Veranstaltungsteilnehmer. Die Gesamtprüfung kostet 235 €. Sie erhalten nach Ihrer Anmeldung einen Gebührenbescheid.\n</div>\n<h2> Prüfungstermine und Anmeldung</h2>\n<div class=\"text\">\nDie <strong>schriftliche Prüfung </strong>wird an dem unten genannten Termin angeboten, die mündliche Prüfung wird <strong>in der Regel ca. ein bis zwei Wochen </strong>danach terminiert:\n</div>\n<table>\n<tbody>\n<tr>\n<td>Tag</td>\n<td>Datum</td>\n<td>Ort</td>\n<td>Status</td>\n</tr>\n<tr>\n<td>Mittwoch</td>\n<td><strong>4. März 2026</strong></td>\n<td>IHK Hanau<br>Am Pedro-Jung-Park 14<br>63450 Hanau</td>\n<td>ausgebucht </td>\n</tr>\n<tr>\n<td>Freitag</td>\n<td><strong>08. Mai 2026</strong></td>\n<td>IHK Hanau<br>Am Pedro-Jung-Park 14<br>63450 Hanau</td>\n<td><a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"https://www.ihk.de/hanau/standort/verkehr-und-logistik/taxen-und-mietwagenverkehr/anmeldeformular-5880078\" target=\"_blank\" rel=\"noopener\">Anmeldung möglich</a></td>\n</tr>\n<tr>\n<td>Donnerstag</td>\n<td><strong>17. September 2026</strong></td>\n<td>IHK Hanau<br>Am Pedro-Jung-Park 14<br>63450 Hanau</td>\n<td><a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"https://www.ihk.de/hanau/standort/verkehr-und-logistik/taxen-und-mietwagenverkehr/anmeldeformular-5880078\" target=\"_blank\" rel=\"noopener\">Anmeldung möglich</a></td>\n</tr>\n<tr>\n<td>Dienstag</td>\n<td><strong>08. Dezember 2026</strong></td>\n<td>IHK Hanau<br>Am Pedro-Jung-Park 14<br>63450 Hanau</td>\n<td><a data-linktypeicon=\"CMExternalLink\" title=\"externer Link\" href=\"https://www.ihk.de/hanau/standort/verkehr-und-logistik/taxen-und-mietwagenverkehr/anmeldeformular-5880078\" target=\"_blank\" rel=\"noopener\">Anmeldung möglich</a></td>\n</tr>\n</tbody>\n</table>\n<div class=\"text\">\n<br>\n</div>\n<div class=\"text\">\n* Die Anzahl der Plätze ist begrenzt.\n</div>\n<div class=\"text\">\nTermine nur für die mündliche Wiederholungsprüfung bitte per Mail anfragen.\n</div>\n</div> </div>\n<div class=\"print-share\">\n<ul class=\"print-share-list \">\n<li>\n<a href=\"#\" class=\"share-mail\" id=\"teilen\">teilen </a>\n</li>\n<li>\n<a href=\"?print=true&amp;printsrc=button\" class=\"print-btn\"\nonmousedown=\"if (typeof (ET_Event) !== 'undefined') {_etracker.sendEvent(new et_ClickEvent('Dokument drucken', 'Seitenfunktion'))}\"\ntitle=\"Dokument drucken\">drucken </a>\n</li>\n</ul>\n<div class=\"bookmarks\" id=\"socialbookmarks\">\n<ul class=\"social-icons\">\n<li><a class=\"social-share twitter\" title=\"Bookmark setzen bei: Twitter\"\nonclick=\"window.open('https://twitter.com/intent/tweet?src_ref='+encodeURIComponent(location.href)+'&url='+encodeURIComponent(location.href));return false;\"\n